    owl:versionInfo "0.2.0" .

jfibo:DisclosureClaim a owl:Class ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/>,
        <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "An auditable claim extracted from, or inferred from, a disclosure document with source, time, validity, information status, and (optionally) normative status."@en ;
    skos:prefLabel "disclosure claim"@en,
        "開示主張"@ja ;
    skos:scopeNote "Atomic; use subclasses for specific claim shapes (PolicyShareholding, MajorShareholderClaim, BorrowingsClaim, MainBankCandidate, CrossShareholdingClaim)."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

<https://w3id.org/jfibo/ontology/JP/information-status/> a owl:Ontology ;
    rdfs:label "J-FIBO Information Status"@en,
        "金融意味基盤・日本版 情報状態"@ja ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    dcterms:source <https://spec.edmcouncil.org/fibo/> ;
    owl:versionIRI <https://w3id.org/jfibo/ontology/JP/information-status/0.2.0/> ;
    owl:versionInfo "0.2.0" .

<https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> a prov:Activity ;
    dcterms:date "2026-05-25"^^xsd:date ;
    rdfs:isDefinedBy jfibo: ;
    skos:definition "Increase EDINET coverage (width + depth); honor official EDINET bilingual labels and XBRL metadata on alignment concepts; materialize BorrowingsClaim and add CommercialPaperClaim from real MUFG schedule; reframe README around roles / responsibilities / regimes / relationships."@en ;
    prov:startedAtTime "2026-05-25T00:00:00+09:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> .

<https://w3id.org/jfibo/ontology/JP/disclosure-claim/> a owl:Ontology ;
