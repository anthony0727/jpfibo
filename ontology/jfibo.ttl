jfibo:EDINETTaxonomyElement a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/edinet-alignment/> ;
    rdfs:subClassOf skos:Concept ;
    skos:definition "An XBRL taxonomy element from the EDINET taxonomy, represented as a SKOS concept for alignment and benchmark traceability."@en ;
    skos:prefLabel "EDINET taxonomy element"@en,
        "EDINETタクソノミ要素"@ja ;
    skos:scopeNote "This is an alignment handle; the authoritative element remains the FSA-published EDINET XBRL taxonomy."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

<https://w3id.org/jfibo/ontology/JP/edinet-alignment/> a owl:Ontology ;
    rdfs:label "J-FIBO EDINET Alignment"@en,
        "金融意味基盤・日本版 EDINET整合"@ja ;
