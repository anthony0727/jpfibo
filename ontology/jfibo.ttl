<https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> a prov:Activity ;
    dcterms:date "2026-05-25"^^xsd:date ;
    rdfs:isDefinedBy jfibo: ;
    skos:definition "Bootstrap J-FIBO v0.1 with EDINET alignment and information-status vocabulary."@en ;
    prov:startedAtTime "2026-05-25T00:00:00+09:00"^^xsd:dateTime ;
