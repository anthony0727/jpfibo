<https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> a prov:Activity ;
    dcterms:date "2026-05-25"^^xsd:date ;
    rdfs:isDefinedBy jfibo: ;
    skos:definition "Finalize ontology with normative-status / reporting-regime / document-type / holder-role vocab, atomic claim types, and the EDINET-family `jfibo:` prefix."@en ;
    prov:startedAtTime "2026-05-25T00:00:00+09:00"^^xsd:dateTime ;
