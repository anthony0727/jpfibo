@prefix cmns-org: <https://www.omg.org/spec/Commons/Organizations/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-be-le-cb: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/CorporateBodies/> .
@prefix fibo-sec-eq-eq: <https://spec.edmcouncil.org/fibo/ontology/SEC/Equities/EquityInstruments/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix jpfibo: <https://w3id.org/jpfibo/ontology/JP/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

jpfibo:EDINETDisclosureDocument a owl:Class ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy jpfibo: ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "A disclosure document submitted through EDINET and used as evidence for J-FIBO disclosure claims."@en ;
    skos:prefLabel "EDINET disclosure document"@en,
        "EDINET開示書類"@ja ;
    skos:scopeNote "Represents the document as an evidence object; document type, filer, and taxonomy facts should be modeled separately."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:GodoKaisha a owl:Class ;
    dcterms:source <https://www.japaneselawtranslation.go.jp/en/laws/view/3206> ;
    rdfs:isDefinedBy jpfibo: ;
    rdfs:subClassOf cmns-org:FormalOrganization ;
    skos:definition "Japanese limited liability company under the Companies Act of Japan, modeled as a formal organization with member equity interests."@en ;
    skos:prefLabel "godo kaisha"@en,
        "合同会社"@ja ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "align" ;
    jpfibo:status "proposed" .

jpfibo:JapaneseListedShare a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy jpfibo: ;
    rdfs:subClassOf fibo-sec-eq-eq:ListedShare ;
    skos:definition "A listed share of an issuer whose disclosure is represented in Japanese securities reporting data."@en ;
    skos:prefLabel "Japanese listed share"@en,
        "日本上場株式"@ja ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "align" ;
    jpfibo:status "proposed" .

jpfibo:KabushikiKaisha a owl:Class ;
    dcterms:source <https://www.japaneselawtranslation.go.jp/en/laws/view/3206> ;
    rdfs:isDefinedBy jpfibo: ;
    rdfs:subClassOf fibo-be-le-cb:Corporation ;
    skos:definition "Japanese stock company under the Companies Act of Japan, modeled as a corporation whose ownership interests are divided into shares."@en ;
    skos:prefLabel "kabushiki kaisha"@en,
        "株式会社"@ja ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "align" ;
    jpfibo:status "proposed" .

jpfibo:SougouShousha a owl:Class ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy jpfibo: ;
    rdfs:subClassOf fibo-be-le-cb:Corporation ;
    skos:definition "Japanese general-trading-company corporate type with diversified trading, investment, and project-finance activities."@en ;
    skos:prefLabel "sougou shousha (general trading company)"@en,
        "総合商社"@ja ;
    skos:scopeNote "Use only when the entity's primary self-identification is sougou shousha; this is a customary classification, not a statutory legal form."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.2-finalize> ;
    jpfibo:level "align" ;
    jpfibo:status "proposed" .

<https://w3id.org/jpfibo/session/2026-05-25-v0.2-finalize> a prov:Activity ;
    dcterms:date "2026-05-25"^^xsd:date ;
    rdfs:isDefinedBy jpfibo: ;
    skos:definition "Finalize ontology with normative-status / reporting-regime / document-type / holder-role vocab, atomic claim types, and the EDINET-family `jpfibo:` prefix."@en ;
    prov:startedAtTime "2026-05-25T00:00:00+09:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> .

<https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> a prov:Activity ;
    dcterms:date "2026-05-25"^^xsd:date ;
    rdfs:isDefinedBy jpfibo: ;
    skos:definition "Bootstrap J-FIBO v0.1 with EDINET alignment and information-status vocabulary."@en ;
    prov:startedAtTime "2026-05-25T00:00:00+09:00"^^xsd:dateTime ;
    prov:wasAssociatedWith <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> .

<https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> a prov:Agent,
        foaf:Agent ;
    rdfs:isDefinedBy jpfibo: ;
    skos:prefLabel "J-FIBO Working Group (bootstrap)"@en,
        "J-FIBOワーキンググループ（初期）"@ja ;
    skos:scopeNote """Provisional, single-author editorial seed for v0.x. NO Japanese
institutional body has endorsed, reviewed, or participated in J-FIBO.
The contributor / session model exists so that, if a working group
ever forms, term-level attribution can be added without restructuring
the ontology. The bodies that could plausibly play stewardship roles
(Digital Agency, FSA, JPX, FISC, FDUA, an EDM Council Japan Chapter)
are mentioned only as examples of where such attribution could go;
none have been contacted."""@en ;
    foaf:member "J-FIBO Working Group (provisional)" ;
    jpfibo:contributorRole "editor" .

jpfibo: a owl:Ontology ;
    rdfs:label "J-FIBO Core"@en,
        "金融意味基盤・日本版 コア"@ja ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    dcterms:source <https://spec.edmcouncil.org/fibo/> ;
    owl:versionIRI <https://w3id.org/jpfibo/ontology/JP/core/0.2.0/> ;
    owl:versionInfo "0.2.0" .

