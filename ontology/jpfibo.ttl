jpfibo:InferredHypothesis a owl:NamedIndividual,
        jpfibo:NormativeStatus ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/normative-status/> ;
    skos:definition "A claim that exists only as the J-FIBO consumer's inference; it has no external normative force."@en ;
    skos:prefLabel "inferred hypothesis"@en,
        "推論仮説"@ja ;
    skos:scopeNote "Pair with informationStatus = Hypothesized; the SHACL shape for MainBankCandidate already enforces this."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.2-finalize> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:InformationBoundary a owl:Class ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/information-status/> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "A boundary describing which information is inside the auditable evidence set for an explanation and which is outside it."@en ;
    skos:prefLabel "information boundary"@en,
        "情報境界"@ja ;
    skos:scopeNote "Reasoning may explore outside-boundary hypotheses, but claims outside the boundary must not be presented as evidence-backed explanations."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:InformationSet a owl:Class ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/information-status/> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "The bounded set of records, observations, disclosures, and derivations available to an explanation at a stated time."@en ;
    skos:prefLabel "information set"@en,
        "情報集合"@ja ;
    skos:scopeNote "Use to separate auditable evidence from unavailable latent variables, counterfactuals, and predictions."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:InstitutionalExpectation a owl:NamedIndividual,
        jpfibo:NormativeStatus ;
    dcterms:source <https://www.nber.org/papers/w23715> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/normative-status/> ;
    skos:definition "A claim about an institutional norm that is not legally binding but is widely observed (e.g., main-bank monitoring, keiretsu cooperation)."@en ;
    skos:prefLabel "institutional expectation"@en,
        "制度的期待"@ja ;
    skos:scopeNote "Always pair with informationStatus = Hypothesized or EvidenceBackedInferred; never use this as a substitute for a legal obligation."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.2-finalize> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:InstitutionalRelationshipHypothesis a owl:Class ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/institutional-context/> ;
    rdfs:subClassOf jpfibo:DisclosureClaim ;
    skos:definition "A hypothesis about a Japanese institutional finance relationship, represented separately from disclosed legal, accounting, or ownership facts."@en ;
    skos:prefLabel "institutional relationship hypothesis"@en,
        "制度的関係仮説"@ja ;
    skos:scopeNote "Keep this outside factual disclosure unless evidence thresholds and information status explicitly justify an inferred claim."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

