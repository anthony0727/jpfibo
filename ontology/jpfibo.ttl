jpfibo:ADRDepositary a owl:NamedIndividual,
        jpfibo:HolderRole ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/holder-role/> ;
    skos:definition "A depositary bank holding shares as the underlying for an American Depositary Receipt program."@en ;
    skos:prefLabel "ADR depositary"@en,
        "ＡＤＲ預託機関"@ja ;
    skos:scopeNote "Typical example: The Bank of New York Mellon as depositary; the disclosed holder is the depositary, not the ADR holders."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.2-finalize> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:AccountingDisclosure a owl:NamedIndividual,
        jpfibo:NormativeStatus ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/normative-status/> ;
    skos:definition "A claim whose normative force is the accounting / financial-reporting disclosure rule that requires it (e.g., 財務諸表等規則, IFRS-as-adopted)."@en ;
    skos:prefLabel "accounting disclosure"@en,
        "会計開示"@ja ;
    skos:scopeNote "Use for balance-sheet line items, borrowings schedules, and other quantitative financial-statement evidence."@en ;
