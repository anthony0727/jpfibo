jpfibo:Counterfactual a owl:NamedIndividual,
        jpfibo:InformationStatus ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/information-status/> ;
    skos:definition "A claim about what would have happened under conditions that did not occur in the cited evidence."@en ;
    skos:prefLabel "counterfactual"@en,
        "反実仮想"@ja ;
    skos:scopeNote "Always outside direct disclosure; useful for analysis but not for auditable explanation unless clearly marked."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:CrossShareholdingClaim a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/institutional-context/> ;
    rdfs:subClassOf jpfibo:DisclosureClaim ;
    skos:definition "An evidence-backed claim that two entities each hold shares or economically meaningful ownership interests in the other."@en ;
    skos:prefLabel "cross-shareholding claim"@en,
        "相互保有主張"@ja ;
    skos:scopeNote "Requires two separately evidenced holding claims (PolicyShareholding or MajorShareholderClaim); do not infer stable alliance, control, or future support solely from mutual holdings."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:CustodyBank a owl:NamedIndividual,
        jpfibo:HolderRole ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/holder-role/> ;
    skos:definition "A custodian bank holding shares on behalf of foreign or institutional investors."@en ;
    skos:prefLabel "custody bank"@en,
        "カストディ銀行"@ja ;
    skos:scopeNote "Custody banks should not be conflated with beneficial owners in cross-shareholding analyses."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.2-finalize> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:Disclosed a owl:NamedIndividual,
        jpfibo:InformationStatus ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/information-status/> ;
    skos:definition "A fact stated in an official disclosure document or other cited public source."@en ;
    skos:prefLabel "disclosed"@en,
        "開示済み"@ja ;
    skos:scopeNote "Does not by itself assert the fact is economically causal or predictive."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:EvidenceBackedInferred a owl:NamedIndividual,
        jpfibo:InformationStatus ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/information-status/> ;
    skos:definition "A claim inferred from cited evidence under an explicit rule or pattern."@en ;
    skos:prefLabel "evidence-backed inferred"@en,
        "証拠付き推論"@ja ;
    skos:scopeNote "Must cite the rule or evidence pattern and must not be collapsed into disclosed fact."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:EvidenceItem a owl:Class ;
