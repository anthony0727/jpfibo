jpfibo:BeneficialHolder a owl:NamedIndividual,
        jpfibo:HolderRole ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/holder-role/> ;
    skos:definition "The ultimate beneficial owner of the shares."@en ;
