jpfibo:Hypothesized a owl:NamedIndividual,
        jpfibo:InformationStatus ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/information-status/> ;
    skos:definition "A plausible but not evidence-sufficient claim."@en ;
    skos:prefLabel "hypothesized"@en,
        "仮説"@ja ;
    skos:scopeNote "Use for exploratory institutional patterns such as main-bank candidates before SHACL evidence thresholds are met."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jpfibo/session/2026-05-25-v0.1-bootstrap> ;
    jpfibo:level "propose" ;
    jpfibo:status "proposed" .

jpfibo:IndividualShareholder a owl:NamedIndividual,
        jpfibo:HolderRole ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/> ;
    rdfs:isDefinedBy <https://w3id.org/jpfibo/ontology/JP/holder-role/> ;
    skos:definition "A natural person holding shares in their own name."@en ;
    skos:prefLabel "individual shareholder"@en,
        "個人株主"@ja ;
    skos:scopeNote "Used for founder-shareholders, family-office holders, and other named individuals."@en ;
    prov:wasAttributedTo <https://w3id.org/jpfibo/contributor/jpfibo-wg-bootstrap> ;
