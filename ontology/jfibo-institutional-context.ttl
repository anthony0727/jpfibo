@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix jfibo: <https://w3id.org/jfibo/ontology/JP/core/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

jfibo:CrossShareholdingClaim a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/institutional-context/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "An evidence-backed claim that two entities each hold shares or economically meaningful ownership interests in the other."@en ;
    skos:prefLabel "cross-shareholding claim"@en,
        "相互保有主張"@ja ;
    skos:scopeNote "Requires two separately evidenced holding claims; do not infer stable alliance, control, or future support solely from mutual holdings."@en ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:InstitutionalRelationshipHypothesis a owl:Class ;
    dcterms:source <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/institutional-context/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "A hypothesis about a Japanese institutional finance relationship, represented separately from disclosed legal, accounting, or ownership facts."@en ;
    skos:prefLabel "institutional relationship hypothesis"@en,
        "制度的関係仮説"@ja ;
    skos:scopeNote "Keep this outside factual disclosure unless evidence thresholds and information status explicitly justify an inferred claim."@en ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:MainBankCandidate a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html>,
        <https://www.nber.org/papers/w23715> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/institutional-context/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "An evidence-backed hypothesis that a bank may function as a primary lender, monitor, or distress-coordination counterparty for an entity."@en ;
    skos:prefLabel "main-bank candidate"@en,
        "メインバンク候補"@ja ;
    skos:scopeNote "Not a contractual relation and not a future support guarantee; instantiate only from disclosed borrowing, shareholding, persistence, or explicit narrative evidence."@en ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

<https://w3id.org/jfibo/ontology/JP/institutional-context/> a owl:Ontology ;
    rdfs:label "J-FIBO Institutional Context"@en,
        "金融意味基盤・日本版 制度的文脈"@ja ;
    dcterms:license <https://opensource.org/licenses/MIT> ;
    dcterms:source <https://spec.edmcouncil.org/fibo/> ;
    owl:versionIRI <https://w3id.org/jfibo/ontology/JP/institutional-context/0.1.0/> ;
    owl:versionInfo "0.1.0" .

