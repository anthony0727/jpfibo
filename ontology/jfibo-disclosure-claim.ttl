@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix jfibo: <https://w3id.org/jfibo/ontology/JP/core/> .
@prefix jpcrp_cor: <http://disclosure.edinet-fsa.go.jp/taxonomy/jpcrp/2025-11-01/jpcrp_cor#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

jfibo:CommercialPaperClaim a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "A disclosure claim about commercial-paper issuance, typically the parenthetical schedule appended to the borrowings table for banks and other treasury-active filers. One claim per row (issuance program or period)."@en ;
    skos:prefLabel "commercial paper claim"@en,
        "コマーシャル・ペーパー残高開示"@ja ;
    skos:scopeNote "For banks, CP issuance is reported alongside but separately from 借入金等明細表; we model it as its own atomic claim so totals are not double-counted."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:EvidenceItem a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html>,
        <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "A cited source fragment, taxonomy fact, table row, text block, or document section used to support a disclosure claim."@en ;
    skos:prefLabel "evidence item"@en,
        "証拠項目"@ja ;
    skos:scopeNote "Evidence items should retain the EDINET element name or source locator whenever available."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:PolicyShareholding a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html>,
        <https://www.jpx.co.jp/english/equities/listing/cg/index.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "A disclosed shareholding held for purposes other than pure investment, represented as an evidence-backed disclosure claim rather than as a bare ownership edge."@en ;
    skos:prefLabel "policy shareholding"@en,
        "政策保有株式"@ja ;
    skos:scopeNote "Aligns to EDINET elements for specified investment shares held for purposes other than pure investment; use jfibo:hasHoldingPurpose and cited evidence."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:mapsToEdinetElement jpcrp_cor:DetailsOfSpecifiedInvestmentEquitySecuritiesHeldForPurposesOtherThanPureInvestmentReportingCompanyTable,
        jpcrp_cor:PurposesOfHoldingDetailsOfSpecifiedInvestmentEquitySecuritiesHeldForPurposesOtherThanPureInvestmentReportingCompany,
        jpcrp_cor:QuantitativeEffectsOfShareholdingDetailsOfSpecifiedInvestmentSharesHeldForPurposesOtherThanPureInvestmentReportingCompany ;
    jfibo:status "proposed" .

jfibo:hasAverageRate a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Weighted-average interest rate (平均利率) for a borrowings or commercial-paper class, expressed as a percentage literal."@en ;
    skos:prefLabel "average interest rate"@en,
        "平均利率"@ja ;
    skos:scopeNote "Percentage as disclosed; consumers must not multiply by 0.01 without checking the disclosure unit."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasBorrower a owl:ObjectProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:domain jfibo:BorrowingsClaim ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf dcterms:subject ;
    skos:definition "Relates a borrowings claim to the borrower entity (typically the reporting company)."@en ;
    skos:prefLabel "has borrower"@en,
        "借入元"@ja ;
    skos:scopeNote "Use only on borrowings claims; the borrower is typically the EDINET reporting company."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasBorrowingsClassLabel a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdfs:label ;
    skos:definition "Verbatim 区分 label as it appears in 借入金等明細表 (e.g. 借入金, リース債務, 借用金, 再割引手形, コマーシャル・ペーパー)."@en ;
    skos:prefLabel "borrowings class label"@en,
        "借入金区分ラベル"@ja ;
    skos:scopeNote "Use to keep BorrowingsClaim rows joinable back to the verbatim 区分 cell."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasCarryingAmount a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Reported balance-sheet carrying amount for a disclosed shareholding or related evidence item."@en ;
    skos:prefLabel "has carrying amount"@en,
        "貸借対照表計上額"@ja ;
    skos:scopeNote "Currency/unit and reporting date must be carried in the evidence or observation context."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:mapsToEdinetElement jpcrp_cor:BookValueDetailsOfSpecifiedInvestmentEquitySecuritiesHeldForPurposesOtherThanPureInvestmentReportingCompany ;
    jfibo:status "proposed" .

jfibo:hasClosingBalance a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Balance at the end of the period (当期末残高), expressed as a literal number whose unit is captured at the claim level."@en ;
    skos:prefLabel "closing balance"@en,
        "期末残高"@ja ;
    skos:scopeNote "Pair with hasUnitLabel; do not auto-convert units."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasHolder a owl:ObjectProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:domain jfibo:MajorShareholderClaim ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    skos:definition "Relates a major-shareholder claim to the entity (or natural person) named in the registered-holder column."@en ;
    skos:prefLabel "has registered holder"@en,
        "名義株主"@ja ;
    skos:scopeNote "This is the registered holder, not necessarily the beneficial owner; pair with hasHolderRole."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasHoldingPurpose a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf skos:note ;
    skos:definition "Textual disclosed purpose of holding a share, especially for shares held for purposes other than pure investment."@en ;
    skos:prefLabel "has holding purpose"@en,
        "保有目的"@ja ;
    skos:scopeNote "Preserve source wording; later controlled purpose taxonomies may be aligned separately."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:mapsToEdinetElement jpcrp_cor:PurposesOfHoldingDetailsOfSpecifiedInvestmentEquitySecuritiesHeldForPurposesOtherThanPureInvestmentReportingCompany ;
    jfibo:status "proposed" .

jfibo:hasInvestor a owl:ObjectProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:domain jfibo:DisclosureClaim ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    skos:definition "Relates a shareholding claim to the entity reported or inferred to hold the shares."@en ;
    skos:prefLabel "has investor"@en,
        "投資者"@ja ;
    skos:scopeNote "Use only on claims/evidence, not as a direct timeless ownership fact."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasIssuer a owl:ObjectProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf dcterms:subject ;
    skos:definition "Relates a shareholding claim to the issuer of the held shares."@en ;
    skos:prefLabel "has issuer"@en,
        "発行者"@ja ;
    skos:scopeNote "Use with a cited security name, EDINET code, security code, or entity resolver output."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasLender a owl:ObjectProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:domain jfibo:BorrowingsClaim ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    skos:definition "Relates a borrowings claim to the lender entity."@en ;
    skos:prefLabel "has lender"@en,
        "貸出元"@ja ;
    skos:scopeNote "Use only on borrowings claims; pair with an entity resolver output for the lender."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasOpeningBalance a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Balance at the start of the period (当期首残高), expressed as a literal number whose unit is captured at the claim level."@en ;
    skos:prefLabel "opening balance"@en,
        "期首残高"@ja ;
    skos:scopeNote "Pair with hasUnitLabel; do not auto-convert units."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasOwnershipPercentage a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Reported percentage of issued shares represented by a holder's position."@en ;
    skos:prefLabel "has ownership percentage"@en,
        "所有株式数の割合"@ja ;
    skos:scopeNote "Decimal value; the basis (issued shares excluding/including treasury) should be carried in the evidence context."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasRepaymentDeadline a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Stated repayment-deadline range (返済期限) as a verbatim disclosure literal; structured parsing is intentionally not enforced because the disclosure is often a free-form range."@en ;
    skos:prefLabel "repayment deadline"@en,
        "返済期限"@ja ;
    skos:scopeNote "Often a Japanese-month-range string such as '2024年 1月〜2051年 10月'; intentionally preserved verbatim."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasShareCount a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "Reported number of shares in a disclosed shareholding claim."@en ;
    skos:prefLabel "has share count"@en,
        "株式数"@ja ;
    skos:scopeNote "Unit should be shares; reported thresholds and omissions are modeled as evidence status, not guessed values."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:mapsToEdinetElement jpcrp_cor:NumberOfSharesHeldDetailsOfSpecifiedInvestmentEquitySecuritiesHeldForPurposesOtherThanPureInvestmentReportingCompany ;
    jfibo:status "proposed" .

jfibo:hasShareholderRank a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdf:value ;
    skos:definition "1-based rank in the 大株主の状況 ordered list."@en ;
    skos:prefLabel "has shareholder rank"@en,
        "大株主順位"@ja ;
    skos:scopeNote "When ties exist, use the order given in the table; do not invent ranks."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:hasUnitLabel a owl:DatatypeProperty ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subPropertyOf rdfs:label ;
    skos:definition "Verbatim unit label as disclosed (e.g. 百万円, ％), preserved without unit conversion so the claim remains auditable against the source row."@en ;
    skos:prefLabel "has unit label"@en,
        "単位ラベル"@ja ;
    skos:scopeNote "Examples: 百万円, 千円, ％. Stored as a label so claims remain auditable against the source row without silent unit conversion."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.5-coverage> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

jfibo:MajorShareholderClaim a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "A disclosed ranked entry in a 大株主の状況 table, recording a registered holder, address, shareholding count, ownership percentage, and rank."@en ;
    skos:prefLabel "major shareholder claim"@en,
        "大株主主張"@ja ;
    skos:scopeNote "Always pair with a HolderRole; registered-holder rows from trust banks must not be conflated with beneficial ownership."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:mapsToEdinetElement jpcrp_cor:MajorShareholdersTextBlock ;
    jfibo:status "proposed" .

jfibo:BorrowingsClaim a owl:Class ;
    dcterms:source <https://www.fsa.go.jp/search/20251111.html> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf jfibo:DisclosureClaim ;
    skos:definition "A disclosed borrowing from a named lender, with balance, weighted-average rate, and repayment period."@en ;
    skos:prefLabel "borrowings claim"@en,
        "借入金主張"@ja ;
    skos:scopeNote "Use the borrowings schedule (借入金等明細表) as evidence; lender role should be tagged when distinct from a vanilla bank-corporate loan."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.2-finalize> ;
    jfibo:level "propose" ;
    jfibo:mapsToEdinetElement jpcrp_cor:AnnexedConsolidatedDetailedScheduleOfBorrowingsTextBlock,
        jpcrp_cor:AnnexedDetailedScheduleOfBorrowingsFinancialStatementsTextBlock ;
    jfibo:status "proposed" .

jfibo:DisclosureClaim a owl:Class ;
    dcterms:source <https://disclosure2.edinet-fsa.go.jp/>,
        <https://www.w3.org/TR/prov-o/> ;
    rdfs:isDefinedBy <https://w3id.org/jfibo/ontology/JP/disclosure-claim/> ;
    rdfs:subClassOf prov:Entity ;
    skos:definition "An auditable claim extracted from, or inferred from, a disclosure document with source, time, validity, information status, and (optionally) normative status."@en ;
    skos:prefLabel "disclosure claim"@en,
        "開示主張"@ja ;
    skos:scopeNote "Atomic; use subclasses for specific claim shapes (PolicyShareholding, MajorShareholderClaim, BorrowingsClaim, MainBankCandidate, CrossShareholdingClaim)."@en ;
    prov:wasAttributedTo <https://w3id.org/jfibo/contributor/jfibo-wg-bootstrap> ;
    prov:wasGeneratedBy <https://w3id.org/jfibo/session/2026-05-25-v0.1-bootstrap> ;
    jfibo:level "propose" ;
    jfibo:status "proposed" .

